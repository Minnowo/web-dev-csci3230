{
	"name": "backend",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"lint": "eslint . --ext .ts",
		"format": "prettier --write .",
		"start": "node dist/app.js",
		"dev": "tsx watch src/index.ts",
		"build": "tsc"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"better-sqlite3": "^12.8.0",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.28.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.33.0",
		"@typescript-eslint/parser": "^8.33.0",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"prettier": "3.6.2",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.33.0"
	},
	"prettier": {
		"tabWidth": 4,
		"useTabs": true,
		"semi": true,
